{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "palworld-dashboard": {
      "projectType": "application",
      "root": ".",
      "sourceRoot": "frontend/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/palworld-dashboard",
            "index": "frontend/src/index.html",
            "browser": "frontend/src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "map.jpg",
                "input": "frontend/src/assets",
                "output": "."
              },
              {
                "glob": "**/*",
                "input": "frontend/src/assets/images",
                "output": "images"
              }
            ],
            "styles": [
              "frontend/src/assets/bootstrap-grid.min.css",
              "frontend/src/styles.css"
            ],
            "scripts": [],
            "polyfills": ["zone.js"],
            "allowedCommonJsDependencies": [
              "ws"
            ]
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true
            },
            "development": {
              "optimization": false,
              "sourceMap": true,
              "namedChunks": true,
              "extractLicenses": false
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  }
}
